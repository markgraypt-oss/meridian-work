import { useEffect, useState } from "react";
import { useAuth } from "@/hooks/useAuth";
import { useToast } from "@/hooks/use-toast";
import { useLocation } from "wouter";
import TopHeader from "@/components/TopHeader";
import FloatingActionButton from "@/components/FloatingActionButton";
import QuickAddMenu from "@/components/QuickAddMenu";
import { Card } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Heart } from "lucide-react";
import nutritionImg from "@assets/stock_images/healthy_nutrition_fo_20091efb.jpg";
import mindsetImg from "@assets/stock_images/mindset_mental_healt_41bd67a1.jpg";
import exerciseImg from "@assets/stock_images/exercise_fitness_wor_75fff60c.jpg";
import stressImg from "@assets/stock_images/stress_relief_relaxa_5a0ed5c7.jpg";

const educationCategories = [
  {
    id: "nutrition",
    title: "Nutrition",
    href: "/education-lab/nutrition",
    image: nutritionImg,
    testId: "block-nutrition"
  },
  {
    id: "mindset",
    title: "Mindset",
    href: "/education-lab/mindset",
    image: mindsetImg,
    testId: "block-mindset"
  },
  {
    id: "exercise",
    title: "Exercise",
    href: "/education-lab/exercise",
    image: exerciseImg,
    testId: "block-exercise"
  },
  {
    id: "stress",
    title: "Stress",
    href: "/education-lab/stress",
    image: stressImg,
    testId: "block-stress"
  }
];

export default function EducationLab() {
  const { toast } = useToast();
  const { isAuthenticated, isLoading } = useAuth();
  const [, navigate] = useLocation();
  const [showQuickAddMenu, setShowQuickAddMenu] = useState(false);

  useEffect(() => {
    if (!isLoading && !isAuthenticated) {
      toast({
        title: "Unauthorized",
        description: "You are logged out. Logging in again...",
        variant: "destructive",
      });
      setTimeout(() => {
        window.location.href = "/api/login";
      }, 500);
    }
  }, [isAuthenticated, isLoading, toast]);

  if (isLoading) {
    return (
      <div className="min-h-screen w-full flex items-center justify-center bg-background">
        <div className="text-center">
          <div className="animate-spin rounded-full h-32 w-32 border-b-2 border-primary mx-auto mb-4"></div>
          <p className="text-muted-foreground">Loading...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-background pb-20">
      <TopHeader title="Learn" />
      
      <div className="p-6">
        <div className="max-w-4xl mx-auto">
          <div className="flex items-start justify-between mb-6">
            <div>
              <h1 className="text-xl font-bold text-foreground mb-2">
                Executive Learning Paths
              </h1>
              <p className="text-muted-foreground">
                Curated content paths designed to help you master health, performance, and wellness
              </p>
            </div>
            <Button
              variant="outline"
              onClick={() => navigate("/education-lab/bookmarks")}
              className="flex-shrink-0"
              data-testid="button-view-bookmarks"
            >
              <Heart className="h-4 w-4 mr-2" />
              Bookmarks
            </Button>
          </div>

          <div className="grid grid-cols-1 gap-4">
            {educationCategories.map((category) => {
              return (
                <Card
                  key={category.id}
                  onClick={() => navigate(category.href)}
                  className="relative overflow-hidden cursor-pointer group h-40 transition-all hover:shadow-lg"
                  data-testid={category.testId}
                >
                  {/* Background Image */}
                  <div 
                    className="absolute inset-0 bg-cover bg-center"
                    style={{ backgroundImage: `url(${category.image})` }}
                  />
                  
                  {/* Black Overlay with 55% opacity */}
                  <div className="absolute inset-0 bg-black opacity-[0.55] group-hover:opacity-[0.5] transition-opacity" />
                  
                  <div className="relative h-full flex items-center justify-center p-6">
                    <h3 className="text-3xl font-bold text-white">
                      {category.title}
                    </h3>
                  </div>
                </Card>
              );
            })}
          </div>
        </div>
      </div>

      <FloatingActionButton onClick={() => setShowQuickAddMenu(true)} />
      <QuickAddMenu open={showQuickAddMenu} onClose={() => setShowQuickAddMenu(false)} />
    </div>
  );
}
